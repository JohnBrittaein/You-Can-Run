<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/arCameraFragment"
        android:name="com.youcanrun.ar.CameraFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:padding="4dp">

        <Button
            android:id="@+id/btnFilterNormal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="OPTICAL"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#CCCCCC"
            android:layout_margin="2dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:backgroundTint="#333333" />

        <Button
            android:id="@+id/btnFilterPredator"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="HEAT"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#FF6600"
            android:layout_margin="2dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:backgroundTint="#333333" />

        <Button
            android:id="@+id/btnFilterEdge"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="MOTION"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#00FFFF"
            android:layout_margin="2dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:backgroundTint="#333333" />
    </LinearLayout>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start|top"
        android:layout_margin="12dp"
        android:text="X"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:backgroundTint="#CC000000"
        android:textColor="#FF0000" />

    <TextView
        android:id="@+id/txtCurrentFilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="16dp"
        android:text="[ OPTICAL ]"
        android:textColor="#00FF00"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:background="#CC000000"
        android:padding="6dp" />

</FrameLayout>
