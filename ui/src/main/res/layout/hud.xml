<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/hudBackground"
        android:src="@drawable/screen_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"
        android:orientation="vertical" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/proxBottomGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <com.youcanrun.ui.ProxSensorView
        android:id="@+id/ProxSensorView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/proxBottomGuideline" />

    <com.youcanrun.ui.CompassView
        android:id="@+id/CompassView"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/proxBottomGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/verticalGuideline" />

    <com.youcanrun.ui.OdometerView
        android:id="@+id/OdometerView"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_margin="8dp"
        app:layout_constraintEnd_toStartOf="@id/verticalGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/CompassView"
        app:layout_constraintBottom_toTopOf="@id/SpeedometerView"/>

    <com.youcanrun.ui.SpeedometerView
        android:id="@+id/SpeedometerView"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/OdometerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/verticalGuideline"
        app:layout_constraintBottom_toTopOf="@id/camera_button" />

    <com.youcanrun.ui.SignalStrengthView
        android:id="@+id/SignalStrengthView"
        android:layout_width="60dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/proxBottomGuideline"
        app:layout_constraintStart_toEndOf="@id/verticalGuideline"
        app:layout_constraintEnd_toStartOf="@id/SignalSliderView"
        app:layout_constraintBottom_toTopOf="@id/camera_button"
        android:layout_margin="8dp" />

    <com.youcanrun.ui.SignalSliderView
        android:id="@+id/SignalSliderView"
        android:layout_width="60dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/proxBottomGuideline"
        app:layout_constraintStart_toEndOf="@id/SignalStrengthView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/camera_button"
        android:layout_margin="8dp" />

    <ImageButton
        android:id="@+id/camera_button"
        android:src="@drawable/button_base"
        android:layout_width="75dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/quit_button"
        android:layout_width="75dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/button_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/camera_button" />


</androidx.constraintlayout.widget.ConstraintLayout>
