<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="#0D0D0D"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fontFamily="@font/orbitron_bold">

    <View
        android:id="@+id/screen_glow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/screen_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/start_button"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/button_ripple"
        android:elevation="0dp"
        android:fontFamily="@font/orbitron_bold"
        android:padding="16dp"
        android:stateListAnimator="@null"
        android:text="INITIALIZE SCAN"
        android:textColor="@color/primary"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/version_info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/screen_glow" />

    <Button
        android:id="@+id/show_dev_hud_button"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:background="@drawable/button_ripple"
        android:fontFamily="@font/orbitron_bold"
        android:text="dHud"
        android:textColor="@color/primary"

        app:layout_constraintBottom_toTopOf="@+id/start_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.042"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/screen_glow"
        app:layout_constraintVertical_bias="0.05" />

    <TextView
        android:id="@+id/version_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:alpha="0.7"
        android:fontFamily="@font/orbitron_bold"
        android:text="SYSTEM: MK-I | BUILD: 0.1"
        android:textColor="#008866"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
